# Python
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/next-env.d.ts

# Generated IFC + SVG + fragments (derived from data/templates/*.json — rebuild with `make all`)
data/ifc_samples/*.ifc
data/svg_plans/*.svg
data/fragments/
# Pre-built IFCs from the batch validation runs (regenerable from templates)
data/build/*.ifc

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*

# Env files (none currently, just in case)
.env
.env.local
.env*.local

# Training pipeline artifacts (large; rebuild from scripts)
training/data/raw/
training/data/processed/
training/data/stats.json
training/checkpoints/
training/data_test/
# Overnight orchestrator output — auto-generated, regenerable
training/overnight_logs/
MORNING_STATUS.md

# Pinned third-party deps cloned for build
deps/

# Synthetic splat datasets — regenerated by scripts/
/tmp/splat_dataset/

# ── HyperFrames tour pipeline (regenerable from scripts/) ──
# Per-template tour dirs are emitted by scripts/render_template_tour.py.
# We keep ONLY the seed composition (hyperframes-bim-floorplan-tour/index.html
# + meta.json + hyperframes.json) which the script reads as the master template.
experiments/hyperframes-bim-tour-*/
# Render output dirs inside each composition
experiments/*/out/
# Generated SDXL panoramas under each composition's assets/ dir
experiments/*/assets/*.png
# Generated tour MP4s + thumbnails + frame extracts in /public
frontend/public/*_tour.mp4
frontend/public/munich_floorplan_tour.mp4
frontend/public/munich_tour.mp4
frontend/public/tour_thumbs/
frontend/public/tour_frames/
frontend/public/reel_frames/
frontend/public/llama10/

# Local Claude editor config (not portable)
.claude/launch.json
