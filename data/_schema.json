{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FloorPlanTemplate",
  "type": "object",
  "required": ["id", "metadata", "boundary", "rooms", "doors", "windows"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(in|eu)_[a-z0-9_]+$"
    },
    "metadata": {
      "type": "object",
      "required": ["region", "country", "size_label", "total_area_sqm",
                   "bedrooms", "bathrooms", "style", "description",
                   "suitable_for", "tags"],
      "properties": {
        "region": { "enum": ["india", "europe"] },
        "country": { "type": "string" },
        "city_inspiration": { "type": "string" },
        "size_label": { "type": "string" },
        "total_area_sqm": { "type": "number", "minimum": 15, "maximum": 400 },
        "bedrooms": { "type": "integer", "minimum": 0, "maximum": 6 },
        "bathrooms": { "type": "number", "minimum": 0, "maximum": 5 },
        "style": { "type": "string" },
        "description": { "type": "string", "minLength": 30 },
        "suitable_for": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "tags": { "type": "array", "items": { "type": "string" } },
        "vastu_compliant": { "type": "boolean" },
        "kitchen_facing": { "enum": ["N","S","E","W","NE","NW","SE","SW"] }
      }
    },
    "boundary": {
      "type": "object",
      "required": ["polygon", "wall_thickness_mm", "ceiling_height_mm"],
      "properties": {
        "polygon": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "number" }
          }
        },
        "wall_thickness_mm": { "type": "integer", "minimum": 100, "maximum": 400 },
        "ceiling_height_mm": { "type": "integer", "minimum": 2200, "maximum": 4000 },
        "orientation_north_deg": { "type": "number" }
      }
    },
    "rooms": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "type", "polygon"],
        "properties": {
          "id": { "type": "string", "pattern": "^r_[a-z0-9_]+$" },
          "name": { "type": "string" },
          "type": {
            "enum": ["living","kitchen","bedroom","master_bedroom",
                     "bathroom","wc","dining","study","balcony",
                     "utility","pooja","store","corridor","entry",
                     "wardrobe","stairs","parking","kochnische",
                     "diele","abstellraum"]
          },
          "polygon": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          },
          "area_sqm": { "type": "number" },
          "notes": { "type": "string" }
        }
      }
    },
    "doors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "position", "width_mm"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "position": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "number" }
          },
          "width_mm": { "type": "integer", "minimum": 600, "maximum": 3000 },
          "height_mm": { "type": "integer", "default": 2100 },
          "swing": { "enum": ["in", "out", "slide"], "default": "in" },
          "is_main_entry": { "type": "boolean", "default": false }
        }
      }
    },
    "windows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["room", "position", "width_mm"],
        "properties": {
          "room": { "type": "string" },
          "position": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "number" }
          },
          "width_mm": { "type": "integer", "minimum": 400, "maximum": 3000 },
          "height_mm": { "type": "integer", "default": 1200 },
          "sill_mm": { "type": "integer", "default": 900 }
        }
      }
    },
    "floors": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "rooms", "doors", "windows"],
        "properties": {
          "name": { "type": "string" },
          "elevation_mm": { "type": "integer" },
          "ceiling_height_mm": { "type": "integer", "minimum": 2200, "maximum": 4000 },
          "boundary_polygon": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" }
            }
          },
          "rooms": { "type": "array", "minItems": 1 },
          "doors": { "type": "array" },
          "windows": { "type": "array" }
        }
      },
      "description": "Multi-floor templates (duplex/townhouse). When present, top-level rooms/doors/windows must NOT be set — the per-floor arrays replace them."
    }
  }
}
